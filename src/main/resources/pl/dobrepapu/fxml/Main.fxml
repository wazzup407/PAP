<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.ImageView?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="pl.dobrepapu.controller.MainController" stylesheets="@../css/style.css">

    <!-- Lewy panel nawigacji -->
    <left>
        <VBox spacing="15" styleClass="nav-panel">
            <padding>
                <Insets top="20" right="15" bottom="20" left="15"/>
            </padding>
            <Label text="🍽️ DobrePAPu" styleClass="app-title"/>
            <Separator/>
            <Button text="Moje Przepisy" onAction="#showRecipes" maxWidth="Infinity" styleClass="nav-button"/>
            <Button text="Składniki" onAction="#showIngredients" maxWidth="Infinity" styleClass="nav-button"/>
            <Separator/>
            <Button text="⬇️ Importuj Przepis" onAction="#handleImport" maxWidth="Infinity" styleClass="nav-button"/>
            <!-- Tutaj w przyszłości można dać Profil, Import/Eksport -->
        </VBox>
    </left>

    <!-- Środkowa i Prawa kolumna zamknięte w SplitPane -->
    <center>
        <SplitPane dividerPositions="0.35" styleClass="main-split">
            
            <!-- Środkowy panel listy -->
            <VBox spacing="10" styleClass="list-panel">
                <padding>
                    <Insets top="15" right="10" bottom="15" left="10"/>
                </padding>
                
                <HBox spacing="5">
                    <TextField fx:id="searchField" promptText="Szukaj..." HBox.hgrow="ALWAYS"/>
                    <!-- W przyszłości tu ikona lupy -->
                </HBox>
                
                <ListView fx:id="itemListView" VBox.vgrow="ALWAYS" styleClass="item-list"/>
                
                <HBox spacing="10" alignment="CENTER">
                    <Button fx:id="addBtn" text="+" onAction="#handleAdd" styleClass="action-btn" prefWidth="40"/>
                    <Button fx:id="editBtn" text="✏️" onAction="#handleEdit" styleClass="action-btn" prefWidth="40"/>
                    <Button fx:id="exportBtn" text="⬆️" onAction="#handleExport" styleClass="action-btn" prefWidth="40"/>
                    <Button fx:id="deleteBtn" text="-" onAction="#handleDelete" styleClass="action-btn" prefWidth="40"/>
                </HBox>
            </VBox>

            <VBox spacing="15" styleClass="details-panel">
                <padding>
                    <Insets top="20" right="20" bottom="20" left="20"/>
                </padding>
                
                <HBox alignment="CENTER_LEFT" spacing="15">
                    <Label fx:id="detailsTitleLabel" text="Wybierz element" styleClass="details-title" wrapText="true"/>
                    <Label fx:id="detailRatingLabel" style="-fx-font-size: 24px; -fx-text-fill: #FFCC00;"/>
                </HBox>
                <Separator/>
                
                <HBox spacing="20" VBox.vgrow="ALWAYS">
                    <VBox spacing="10" HBox.hgrow="ALWAYS">
                        <Label fx:id="detailInfoLabel" style="-fx-font-weight: bold; -fx-text-fill: #555;"/>
                        
                        <Label text="Sposób przygotowania / Opis:" style="-fx-font-weight: bold;"/>
                        <TextArea fx:id="detailInstructionsArea" VBox.vgrow="ALWAYS" editable="false" wrapText="true" styleClass="details-content"/>
                    </VBox>
                    
                    <VBox spacing="15" prefWidth="200" alignment="TOP_CENTER">
                        <ImageView fx:id="detailImageView" fitWidth="220" preserveRatio="true" style="-fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5);"/>
                        
                        <VBox fx:id="macroBox" spacing="8" style="-fx-background-color: #F2F2F7; -fx-padding: 15; -fx-background-radius: 10;" visible="false">
                            <Label text="Wartości Odżywcze" style="-fx-font-weight: bold; -fx-font-size: 16px;"/>
                            <Separator/>
                            <Label fx:id="macroCaloriesLabel" style="-fx-font-weight: bold;"/>
                            <Label fx:id="macroProteinLabel" />
                            <Label fx:id="macroFatLabel" />
                            <Label fx:id="macroCarbsLabel" />
                        </VBox>
                    </VBox>
                </HBox>
            </VBox>
            
        </SplitPane>
    </center>

</BorderPane>
